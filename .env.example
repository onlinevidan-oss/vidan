# ============================================================
# VIDAN Shop — орчны хувьсагч
# .env.local руу хуулж бодит утгуудаа оруулна уу:
#   cp .env.example .env.local
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — ЗӨВХӨН серверт. QPay callback болон token cache бичихэд хэрэгтэй.
# ⚠️ Хэзээ ч client/нийтэд задлахгүй.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- QPay v2 (merchant) ---
# ДӨРВӨН-ӨЛЗИЙ ХХК — VIDAN
QPAY_USERNAME=VIDAN_MN
QPAY_PASSWORD=your-qpay-password
QPAY_INVOICE_CODE=VIDAN_MN_INVOICE
# Production: https://merchant.qpay.mn/v2  (default)
QPAY_BASE_URL=https://merchant.qpay.mn/v2

# Callback-ийн суурь URL (public домэйн). Local dev-д ngrok гэх мэт tunnel ашиглана.
# Жнь: https://vidan.mn  эсвэл  https://abcд.ngrok.io
QPAY_CALLBACK_BASE_URL=https://your-domain.mn
NEXT_PUBLIC_SITE_URL=https://your-domain.mn

# --- CallPro Text SMS (api-text.callpro.mn) ---
# Захиалгын мэдэгдлийн SMS. Хоосон орхивол SMS илгээхгүй (чимээгүй алгасна).
SMS_API_KEY=your-sms-api-key
SMS_FROM_NUMBER=72272525
SMS_BASE_URL=https://api-text.callpro.mn/v1/sms
# Supabase Auth "Send SMS" hook-ийн гарын үсгийн нууц (Standard Webhooks формат)
SEND_SMS_HOOK_SECRET=v1,whsec_your-hook-secret
